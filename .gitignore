.clang-format
archive_pre_refactor/
venv/
.venv/
__pycache__/
*.pyc
.pytest_cache/

# ==============================================================================
# Local Data, Workspace & Dependency Exclusions
# ==============================================================================
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# IDE settings
.vscode/

# Local third-party library dependencies (such as ONNX Runtime)
third_party/

# Exclude locally exported ONNX models
checkpoints/*.onnx
tools/rl_bridge/checkpoints/*.onnx

# Online training telemetry is generated locally and can exceed GitHub's 100 MB limit.
checkpoints/online_training_telemetry_discrete_ppo.csv

# ==============================================================================
# V2X QoS Experiment Output Exclusions & Whitelist
# ==============================================================================
# Ignore all generated outputs by default (raw simulation traces, bin packets, logs)
outputs/**/*

# Whitelist thesis figures, plots, and tables
!outputs/plots/
!outputs/plots/**/*
!outputs/stats/
!outputs/stats/**/*

# Whitelist specific CSV files required for thesis plotting (rates 10.0, 5.0, 1.0)
!outputs/csv_raw/
!outputs/csv_raw/**/training_trace_10.0_mode*.csv
!outputs/csv_raw/**/training_trace_5.0_mode*.csv
!outputs/csv_raw/**/training_trace_1.0_mode*.csv
!outputs/csv_raw/**/fsm_trace_rate_10.0_mode*.csv
!outputs/csv_raw/**/fsm_trace_rate_5.0_mode*.csv
!outputs/csv_raw/**/fsm_trace_rate_1.0_mode*.csv
!outputs/csv_raw/**/amplification_profile.csv

# ==============================================================================
# RWTH Aachen V2AIX Dataset Exclusions (Compliance with academic non-distribution license)
# ==============================================================================
*v2aix*
inputs/v2aix*
inputs/base_packets/v2aix*
json/
