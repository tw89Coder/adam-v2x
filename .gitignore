.clang-format
archive_pre_refactor/
venv/
.venv/
__pycache__/
*.pyc
.pytest_cache/

# ==============================================================================
# V2X QoS DRL Bridge Local Telemetry Data Exclusion
# ==============================================================================
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# IDE Settings
.vscode/

# Local third-party library dependencies (such as ONNX Runtime)
third_party/

# Exclude locally exported ONNX models
checkpoints/*.onnx
tools/rl_bridge/checkpoints/*.onnx

# Exclude all generated CSV telemetry traces to prevent push lag
outputs/**/*.csv

# Whitelist specific CSV files required for thesis plotting (rates 10.0, 5.0, 1.0)
!outputs/**/training_trace_10.0_mode*.csv
!outputs/**/training_trace_5.0_mode*.csv
!outputs/**/training_trace_1.0_mode*.csv
!outputs/**/fsm_trace_rate_10.0_mode*.csv
!outputs/**/fsm_trace_rate_5.0_mode*.csv
!outputs/**/fsm_trace_rate_1.0_mode*.csv
!outputs/**/amplification_profile.csv